APP_NAME=Ops Pulse API
APP_ENV=local
DEBUG=true
API_VERSION=0.1.0
# Local dev (SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./ops_pulse.db
# Local PostgreSQL (example; set real password in .env)
DATABASE_URL=postgresql+asyncpg://postgres:change-me@127.0.0.1:5432/ops_pulse
API_TOKEN=
JWT_ACCESS_SECRET=dev-access-secret-change-me-32-bytes
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32-bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_SECOND=5
